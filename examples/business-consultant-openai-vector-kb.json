            },
            {
              "id": "search-results",
              "name": "searchResults",
              "value": "={{$('Score Retrieval Quality').first().json.acceptedResultsList}}",
              "type": "array"
            },
            {
              "id": "response-id",
              "name": "openaiResponseId",
              "value": "={{$('Score Retrieval Quality').first().json.rawResponseId}}",
