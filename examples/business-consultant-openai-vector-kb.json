      ],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "request-id",
              "name": "requestId",
              "value": "={{$json.headers['x-request-id'] || $json.body.requestId || $execution.id}}",
              "type": "string"
            },
            {
              "id": "query",
              "name": "query",
              "value": "={{$json.body.query || ''}}",
              "type": "string"
            },
            {
              "id": "industry",
              "name": "industry",
              "value": "={{$json.body.industry || 'general'}}",
              "type": "string"
            },
            {
              "id": "geography",
              "name": "geography",
              "value": "={{$json.body.geography || 'global'}}",
              "type": "string"
            },
            {
              "id": "report-type",
              "name": "reportType",
              "value": "={{$json.body.reportType || 'industry-report'}}",
              "type": "string"
            },
            {
              "id": "response-language",
              "name": "responseLanguage",
              "value": "={{$json.body.responseLanguage || 'zh-CN'}}",
              "type": "string"
            },
            {
              "id": "model",
              "name": "model",
              "value": "={{$json.body.model || $env.OPENAI_RESPONSES_MODEL || 'gpt-4.1'}}",
              "type": "string"
            },
            {
              "id": "vector-store-ids",
              "name": "vectorStoreIdsRaw",
              "value": "={{Array.isArray($json.body.vectorStoreIds) ? $json.body.vectorStoreIds.join(',') : ($json.body.vectorStoreIds || $env.OPENAI_VECTOR_STORE_IDS || '')}}",
              "type": "string"
            },
            {
              "id": "max-sources",
              "name": "maxSources",
              "value": "={{$json.body.maxSources ?? 8}}",
              "type": "number"
            },
            {
              "id": "knowledge-categories",
              "name": "knowledgeCategoriesRaw",
              "value": "={{Array.isArray($json.body.knowledgeCategories) ? $json.body.knowledgeCategories.join(',') : ($json.body.knowledgeCategories || '')}}",
              "type": "string"
            },
            {
              "id": "min-accepted-results",
              "name": "minAcceptedResults",
              "value": "={{$json.body.minAcceptedResults ?? 2}}",
              "type": "number"
            },
            {
              "id": "min-search-score",
              "name": "minSearchScore",
              "value": "={{$json.body.minSearchScore ?? 0.72}}",
              "type": "number"
            }
          ]
        }
      }
    },
    {
      "id": "validate-request",
      "name": "Validate Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        760,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const input = $input.first().json;\nconst errors = [];\nconst vectorStoreIds = String(input.vectorStoreIdsRaw || '').split(',').map((item) => item.trim()).filter(Boolean);\nconst knowledgeCategories = String(input.knowledgeCategoriesRaw || '').split(',').map((item) => item.trim()).filter(Boolean);\nif (!input.query || String(input.query).trim().length < 8) {\n  errors.push('query must be at least 8 characters');\n}\nif (!vectorStoreIds.length) {\n  errors.push('at least one vector store id is required');\n}\nif (Number(input.maxSources) < 1 || Number(input.maxSources) > 20) {\n  errors.push('maxSources must be between 1 and 20');\n}\nif (Number(input.minAcceptedResults) < 1 || Number(input.minAcceptedResults) > Number(input.maxSources)) {\n  errors.push('minAcceptedResults must be between 1 and maxSources');\n}\nif (Number(input.minSearchScore) < 0 || Number(input.minSearchScore) > 1) {\n  errors.push('minSearchScore must be between 0 and 1');\n}\nreturn [{ json: { ...input, vectorStoreIds, knowledgeCategories, isValid: errors.length === 0, validationErrors: errors } }];"
      }
    },
    {
      "id": "is-request-valid",
      "name": "Is Request Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1020,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "request-valid-condition",
              "leftValue": "={{$json.isValid}}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "build-validation-error-response",
      "name": "Build Validation Error Response",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1280,
        460
      ],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "status",
              "name": "status",
              "value": "invalid_request",
              "type": "string"
            },
            {
              "id": "request-id",
              "name": "requestId",
              "value": "={{$('Validate Request').first().json.requestId}}",
              "type": "string"
            },
            {
              "id": "errors",
              "name": "errors",
              "value": "={{$('Validate Request').first().json.validationErrors}}",
              "type": "array"
            },
            {
              "id": "message",
              "name": "message",
              "value": "Provide a clear business question and at least one OpenAI vector store id.",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "respond-validation-error",
      "name": "Respond Validation Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1540,
        460
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{$json}}",
        "options": {
          "responseCode": 400
        }
      }
    },
    {
      "id": "openai-grounded-report",
      "name": "OpenAI Grounded Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1280,
        220
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/responses",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.OPENAI_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "X-Client-Request-Id",
              "value": "={{$json.requestId}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{(() => { const tool = { type: 'file_search', vector_store_ids: $json.vectorStoreIds, max_num_results: Number($json.maxSources) }; if (Array.isArray($json.knowledgeCategories) && $json.knowledgeCategories.length) { tool.filters = { type: 'in', key: 'category', value: $json.knowledgeCategories }; } return { model: $json.model, store: false, instructions: 'You are a conservative business consulting analyst. Use only information grounded in file_search results from the provided vector stores. Do not invent market numbers, company facts, or trends. If evidence is weak or incomplete, explicitly say so. Return JSON with keys: executive_summary, market_overview, opportunity_analysis, risk_analysis, recommendations, citations, limitations.', input: `Question: ${$json.query}\\nIndustry: ${$json.industry}\\nGeography: ${$json.geography}\\nReport Type: ${$json.reportType}\\nResponse Language: ${$json.responseLanguage}\\nUse only retrieved knowledge base evidence.`, tools: [tool], include: ['file_search_call.results'], text: { format: { type: 'json_object' } } }; })()}}",
        "options": {
          "timeout": 45000
        }
      }
    },
    {
      "id": "parse-openai-response",
      "name": "Parse OpenAI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        220
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const request = $('Validate Request').first().json;\nconst payload = $input.first().json;\nconst output = Array.isArray(payload.output) ? payload.output : [];\nconst fileSearchCalls = output.filter((item) => item.type === 'file_search_call');\nconst searchResults = fileSearchCalls.flatMap((item) => Array.isArray(item.results) ? item.results : []);\nconst outputTexts = output\n  .filter((item) => item.type === 'message')\n  .flatMap((item) => Array.isArray(item.content) ? item.content : [])\n  .filter((item) => item.type === 'output_text');\nlet report = {};\nconst firstText = payload.output_text || outputTexts[0]?.text || '';\nif (firstText) {\n  try {\n    report = JSON.parse(firstText);\n  } catch (error) {\n    report = { rawText: firstText };\n  }\n}\nconst citations = outputTexts.flatMap((item) => Array.isArray(item.annotations) ? item.annotations : []).map((annotation) => ({ file_id: annotation.file_id || '', filename: annotation.filename || '', index: annotation.index ?? null, type: annotation.type || '' }));\nreturn [{ json: { requestId: request.requestId, query: request.query, industry: request.industry, geography: request.geography, reportType: request.reportType, responseLanguage: request.responseLanguage, model: request.model, vectorStoreIds: request.vectorStoreIds, knowledgeCategories: request.knowledgeCategories, maxSources: request.maxSources, minAcceptedResults: request.minAcceptedResults, minSearchScore: request.minSearchScore, report, searchResults, citations, rawResponseId: payload.id || '' } }];"
      }
    },
    {
      "id": "score-retrieval-quality",
      "name": "Score Retrieval Quality",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1800,
        220
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const input = $input.first().json;\nconst results = Array.isArray(input.searchResults) ? input.searchResults : [];\nconst accepted = results.filter((result) => Number(result.score ?? 0) >= Number(input.minSearchScore));\nconst uniqueFiles = [...new Set(accepted.map((result) => result.file_id || result.filename || '').filter(Boolean))];\nconst averageScore = accepted.length ? accepted.reduce((sum, result) => sum + Number(result.score || 0), 0) / accepted.length : 0;\nreturn [{ json: { ...input, grounding: { totalResults: results.length, acceptedResults: accepted.length, uniqueFiles: uniqueFiles.length, averageScore: Number(averageScore.toFixed(4)) }, acceptedResultsList: accepted, groundingSufficient: accepted.length >= Number(input.minAcceptedResults) } }];"
      }
    },
    {
      "id": "is-grounding-sufficient",
      "name": "Is Grounding Sufficient?",
