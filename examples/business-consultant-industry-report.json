          }
        ],
        [
          {
            "node": "Build Low Confidence Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Low Confidence Response": {
      "main": [
        [
          {
            "node": "Respond Low Confidence",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate Advisory Report": {
      "main": [
        [
          {
            "node": "Finalize Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Finalize Response": {
      "main": [
